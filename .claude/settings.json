{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const f=j.tool_input?.file_path||j.tool_response?.filePath||'';if(!f.includes('SchulBusserl.ClientApp'))process.exit(0);const{execSync}=require('child_process');try{execSync('npm run lint:local',{cwd:'src/SchulBusserl.ClientApp',stdio:'inherit'})}catch(e){process.exit(1)}})\"",
            "timeout": 300,
            "statusMessage": "Running lint:local..."
          }
        ]
      }
    ]
  }
}
